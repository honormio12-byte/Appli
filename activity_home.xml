<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/bg_nav"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SITO TV"
            android:textColor="@color/accent_red"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"/>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvCurrentPlaylist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginEnd="16dp"/>

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="220dp"
            android:layout_height="36dp"
            android:hint="@string/search"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:background="@drawable/bg_search"
            android:paddingHorizontal="12dp"
            android:textSize="14sp"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true"/>

    </LinearLayout>

    <!-- Nav Tabs -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/bg_card"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@+id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnLive"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/live_tv"
            android:textColor="@color/accent_red"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnMovies"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/movies"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:alpha="0.5"/>

        <Button
            android:id="@+id/btnSeries"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/series"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:alpha="0.5"/>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <Button
            android:id="@+id/btnPlaylists"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/playlists"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"/>

        <Button
            android:id="@+id/btnSettings"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/settings"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"/>

    </LinearLayout>

    <!-- Sidebar: Categories -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategories"
        android:layout_width="160dp"
        android:layout_height="0dp"
        android:background="@color/bg_nav"
        android:paddingVertical="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/navBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Main: Channel Grid -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/navBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/rvCategories"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChannels"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:clipToPadding="false"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/accent_red"/>

        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#FF6B6B"
            android:textSize="16sp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvNoPlaylist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/no_playlist"
            android:textColor="@color/text_secondary"
            android:textSize="20sp"
            android:gravity="center"
            android:visibility="gone"/>

    </FrameLayout>

    <!-- Playlist Panel (shown when btnPlaylists clicked) -->
    <LinearLayout
        android:id="@+id/playlistPanel"
        android:layout_width="320dp"
        android:layout_height="0dp"
        android:background="@color/bg_card"
        android:orientation="vertical"
        android:elevation="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/navBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="@color/bg_nav">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MES PLAYLISTS"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnAddPlaylist"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="+ Ajouter"
                android:textSize="13sp"
                android:backgroundTint="@color/accent_red"
                android:textColor="@color/text_primary"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlaylists"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
